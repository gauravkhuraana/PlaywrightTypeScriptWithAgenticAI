# Copy this file to `.env` and adjust values as needed.
# None of these values are required - every variable has a safe default in code.

# Base URL for the application under test
BASE_URL=https://example.com

# Base URL for the API under test
API_BASE_URL=https://httpbin.org

# Target environment (used by TestDataManager to load the right data file)
TEST_ENV=staging

# Enable verbose debug-level logging
DEBUG=

# If set, the Logger will also persist logs to test-results/logs/*.log
LOG_TO_FILE=

# Optional: start a local web server before running tests (see playwright.config.ts)
START_SERVER=

# Optional notification webhooks consumed by src/reporters/custom-reporter.ts
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
